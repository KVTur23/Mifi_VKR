{
  "model_name": "Qwen/Qwen3-14B",
  "method": "tinylora",
  "task_type": "SEQ_CLS",
  "num_labels": 36,
  "max_seq_length": 2048,

  "peft_config": {
    "r": 2,
    "u": 16,
    "weight_tying": 0.0,
    "target_modules": ["q_proj", "v_proj"],
    "projection_seed": 42,
    "modules_to_save": ["score"]
  },

  "training_params": {
    "num_train_epochs": 8,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 4,
    "gradient_accumulation_steps": 8,
    "learning_rate": 1e-3,
    "lr_scheduler_type": "cosine",
    "warmup_ratio": 0.03,
    "weight_decay": 0.01,
    "optim": "adamw_torch",
    "gradient_checkpointing": true,
    "max_grad_norm": 1.0,
    "logging_steps": 10,
    "save_strategy": "epoch",
    "eval_strategy": "epoch",
    "load_best_model_at_end": true,
    "metric_for_best_model": "macro_f1",
    "greater_is_better": true,
    "save_total_limit": 2,
    "bf16": true,
    "seed": 42
  }
}
