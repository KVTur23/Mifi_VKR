{
  "run_key": "yandexgpt_5_lite_8b_adalora_iter3",
  "model_name": "yandex/YandexGPT-5-Lite-8B-instruct",
  "method": "adalora",
  "task_type": "SEQ_CLS",
  "num_labels": 36,
  "max_seq_length": 2048,
  "trust_remote_code": true,
  "use_class_weights": false,
  "val_split": 0.1,
  "eval_test_each_epoch": true,
  "peft_config": {
    "init_r": 24,
    "target_r": 16,
    "beta1": 0.85,
    "beta2": 0.85,
    "tinit": 80,
    "tfinal": 150,
    "deltaT": 10,
    "lora_alpha": 32,
    "lora_dropout": 0.1,
    "target_modules": [
      "q_proj",
      "k_proj",
      "v_proj",
      "o_proj",
      "gate_proj",
      "up_proj",
      "down_proj"
    ],
    "modules_to_save": [
      "score"
    ],
    "total_step": null
  },
  "training_params": {
    "num_train_epochs": 6,
    "per_device_train_batch_size": 2,
    "per_device_eval_batch_size": 4,
    "gradient_accumulation_steps": 8,
    "learning_rate": 0.0002,
    "lr_scheduler_type": "constant_with_warmup",
    "warmup_ratio": 0.05,
    "weight_decay": 0.05,
    "optim": "adamw_torch",
    "gradient_checkpointing": true,
    "max_grad_norm": 0.5,
    "logging_steps": 10,
    "save_strategy": "epoch",
    "eval_strategy": "epoch",
    "load_best_model_at_end": true,
    "metric_for_best_model": "macro_f1",
    "greater_is_better": true,
    "save_total_limit": 2,
    "bf16": true,
    "seed": 42,
    "label_smoothing_factor": 0.03
  }
}
