{
  "gpu_profiles": {
    "T4": {
      "vram_gb": 16,
      "nllb_batch_size": 32,
      "rubert_batch_size": 16,
      "gpu_memory_utilization": 0.90,
      "enforce_eager": true,
      "nllb_model": "facebook/nllb-200-1.3B"
    },
    "L4": {
      "vram_gb": 24,
      "nllb_batch_size": 32,
      "rubert_batch_size": 32,
      "gpu_memory_utilization": 0.90,
      "enforce_eager": true,
      "nllb_model": "facebook/nllb-200-1.3B"
    },
    "A100_40": {
      "vram_gb": 40,
      "nllb_batch_size": 64,
      "rubert_batch_size": 64,
      "gpu_memory_utilization": 0.92,
      "enforce_eager": true,
      "nllb_model": "facebook/nllb-200-1.3B"
    },
    "A100_80": {
      "vram_gb": 80,
      "nllb_batch_size": 64,
      "rubert_batch_size": 64,
      "gpu_memory_utilization": 0.95,
      "enforce_eager": true,
      "nllb_model": "facebook/nllb-200-1.3B"
    },
    "H100": {
      "vram_gb": 80,
      "nllb_batch_size": 64,
      "rubert_batch_size": 64,
      "gpu_memory_utilization": 0.95,
      "enforce_eager": true,
      "nllb_model": "facebook/nllb-200-1.3B"
    }
  },
  "pipeline": {
    "stage1": {
      "target_count": 15,
      "max_retries": 5,
      "oversample_factor": 5,
      "max_examples_in_prompt": 5
    },
    "stage2": {
      "target_count": 35,
      "max_retries": 5,
      "oversample_factor": 5,
      "originals_only_sources": true,
      "judge_min_score": 4.5,
      "validation_min_text_length": 250,
      "validation_min_length_ratio": 0.7,
      "apply_prompt_leak_filter": false,
      "post_judge_retries": 3,
      "final_fill_below_threshold": true,
      "paraphraser": {
        "model": "fyaronskiy/ruT5-large-paraphraser",
        "batch_size": 8,
        "chunk_max_tokens": 420,
        "output_length_factor": 1.5,
        "output_max_tokens": 512,
        "num_beams": 5,
        "do_sample": true,
        "temperature": 0.8,
        "top_p": 0.95,
        "repetition_penalty": 1.1,
        "encoder_no_repeat_ngram_size": 3,
        "no_repeat_ngram_size": 3,
        "small_class_source_threshold": 6,
        "small_class_temperature": 0.95,
        "temperature_increase_after_attempt": 3,
        "temperature_step": 0.05,
        "max_temperature": 1.1
      }
    },
    "stage3": {
      "target_count": 50,
      "max_retries": 20,
      "oversample_factor": 3,
      "min_judge_score": 2.5,
      "originals_only_sources": true,
      "validation_min_text_length": 250,
      "validation_min_length_ratio": 0.7,
      "apply_prompt_leak_filter": false,
      "translation_chunking": {
        "chunk_max_tokens": 900,
        "output_length_factor": 1.3,
        "output_max_tokens": 1024
      }
    }
  },
  "judge": {
    "min_score": 5.0,
    "max_examples": 5,
    "sampling": {
      "temperature": 0.1,
      "top_p": 0.9,
      "max_tokens": 8
    }
  },
  "validation": {
    "similarity_threshold": 0.95,
    "similarity_threshold_max": 0.98,
    "similarity_threshold_min": 0.5,
    "min_text_length": 500
  },
  "training": {
    "num_epochs": 15,
    "learning_rate": 5e-4,
    "max_length": 256,
    "weight_decay": 0.01
  },
  "finetune": {
    "T4":       {"per_device_batch": 1, "grad_accum": 16, "max_seq": 1024, "bf16": false, "fp16": true},
    "L4":       {"per_device_batch": 1, "grad_accum": 16, "max_seq": 1536, "bf16": true,  "fp16": false},
    "A100_40":  {"per_device_batch": 2, "grad_accum": 8,  "max_seq": 1536, "bf16": true,  "fp16": false},
    "A100_80":  {"per_device_batch": 4, "grad_accum": 4,  "max_seq": 2048, "bf16": true,  "fp16": false},
    "H100":     {"per_device_batch": 4, "grad_accum": 4,  "max_seq": 2048, "bf16": true,  "fp16": false},
    "common": {
      "output_dir": "Data/finetune_checkpoints",
      "results_csv": "results/finetune_results.csv",
      "preds_dir":   "results/",
      "early_stopping_patience": 2
    }
  },
  "prompt_classification": {
    "generation_params": {
      "temperature": 0.1,
      "do_sample": true,
      "top_p": 0.9,
      "repetition_penalty": 1.1,
      "max_new_tokens": 50
    },
    "group_thresholds": {
      "A_min": 50,
      "B_min": 15,
      "C_max": 15
    },
    "k_shots": [0, 1, 3, 5],
    "extract_prediction": {
      "fuzzy_cutoff": 0.6
    },
    "prompt_models": {
      "saiga_8b": {
        "model_name": "IlyaGusev/saiga_llama3_8b",
        "max_context": 8192,
        "dtype": "float16",
        "vram_gb": 16
      },
      "t_lite_8b": {
        "model_name": "t-tech/T-lite-it-1.0",
        "max_context": 32768,
        "dtype": "bfloat16",
        "vram_gb": 16
      },
      "vikhr_12b": {
        "model_name": "Vikhrmodels/Vikhr-Nemo-12B-Instruct-R-21-09-24",
        "max_context": 32768,
        "dtype": "float16",
        "vram_gb": 24
      },
      "qwen_14b": {
        "model_name": "Qwen/Qwen2.5-14B-Instruct",
        "max_context": 32768,
        "dtype": "bfloat16",
        "vram_gb": 28
      },
      "qwen_32b": {
        "model_name": "Qwen/Qwen2.5-32B-Instruct-AWQ",
        "max_context": 32768,
        "quantization": "awq",
        "vram_gb": 20,
        "tensor_parallel_size": 2,
        "enforce_eager": true
      }
    }
  }
}
